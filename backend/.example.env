# Server bind address (0.0.0.0 = listen on all interfaces)
HOST=0.0.0.0

# Server port
PORT=5000

# Auto-reload on code changes (development only)
RELOAD=true

# Comma-separated allowed CORS origins, or * for all
CORS_ORIGINS=*

# Public URL the frontend uses to call this API
BACKEND_URL=http://192.168.0.53:5000

# Input backend: auto | xdotool (X11) | ydotool (Wayland) | pyautogui
INPUT_BACKEND=auto

# X11 session (usually :0 on Pi desktop). Required for xdotool.
DISPLAY=:0

# Path to X authority file (replace pi with your desktop user)
# XAUTHORITY=/home/pi/.Xauthority
